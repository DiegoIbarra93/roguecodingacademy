---
import { nav, primaryCta, site } from '../data/site';

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return href === '/'
    ? pathname === '/'
    : pathname === href || pathname.startsWith(`${href}/`);
}
---

<header class="site-header sticky top-0 z-40 px-3 pt-[max(0.75rem,env(safe-area-inset-top))] sm:px-6 sm:pt-4">
  <div class="glass-header mx-auto max-w-6xl">
    <div class="flex items-center justify-between gap-3 px-3 py-2.5 sm:gap-4 sm:px-5 sm:py-3">
      <a href="/" class="group flex min-w-0 items-center gap-2.5">
        <span
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-app-accent/40 bg-app-accent-subtle font-display text-sm font-bold text-app-accent sm:h-9 sm:w-9"
          aria-hidden="true"
        >
          R
        </span>
        <span class="truncate font-display text-sm font-semibold tracking-tight text-app-text sm:text-base">
          {site.name}
        </span>
      </a>

      <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
        {
          nav.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                class:list={[
                  'rounded-lg px-3 py-2 text-sm transition-colors',
                  active ? 'text-app-accent' : 'text-app-muted hover:text-app-text',
                ]}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>

      <div class="flex shrink-0 items-center gap-2">
        <a
          href={primaryCta.href}
          class="btn-primary hidden !min-h-10 !px-4 !py-2 text-sm sm:inline-flex"
        >
          {primaryCta.label}
        </a>

        <button
          type="button"
          class="nav-toggle"
          id="nav-toggle"
          aria-expanded="false"
          aria-controls="mobile-nav"
          aria-label="Open menu"
        >
          <span class="nav-toggle__bars" aria-hidden="true">
            <span />
          </span>
        </button>
      </div>
    </div>

    <div
      id="mobile-nav"
      class="mobile-nav-panel border-t border-transparent px-3 sm:px-5"
      data-open="false"
      inert
      aria-hidden="true"
    >
      <nav class="flex flex-col gap-1 py-3" aria-label="Mobile">
        {
          nav.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={item.href}
                class:list={[
                  'mobile-nav-link',
                  active
                    ? 'bg-app-accent-subtle text-app-accent'
                    : 'text-app-muted hover:bg-app-surface-2/50 hover:text-app-text',
                ]}
                aria-current={active ? 'page' : undefined}
                data-mobile-nav-link
              >
                {item.label}
              </a>
            );
          })
        }
        <a
          href={primaryCta.href}
          class="btn-primary mt-2 w-full"
          data-mobile-nav-link
        >
          {primaryCta.label}
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  function initMobileNav() {
    const toggle = document.getElementById('nav-toggle');
    const panel = document.getElementById('mobile-nav');
    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

    // Avoid duplicate listeners on astro:page-load re-init
    if (toggle.dataset.navReady === '1') return;
    toggle.dataset.navReady = '1';

    const links = panel.querySelectorAll('[data-mobile-nav-link]');
    let open = false;

    const setOpen = (next: boolean) => {
      open = next;
      toggle.setAttribute('aria-expanded', String(next));
      toggle.setAttribute('aria-label', next ? 'Close menu' : 'Open menu');
      panel.dataset.open = String(next);
      panel.inert = !next;
      panel.setAttribute('aria-hidden', String(!next));
      document.body.classList.toggle('nav-open', next);

      if (next) {
        panel.classList.add('border-app-border/40');
      } else {
        panel.classList.remove('border-app-border/40');
      }
    };

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      setOpen(!open);
    });

    links.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && open) {
        setOpen(false);
        toggle.focus();
      }
    });

    const mq = window.matchMedia('(min-width: 48rem)');
    mq.addEventListener('change', () => {
      if (mq.matches && open) setOpen(false);
    });

    document.addEventListener('click', (e) => {
      if (!open) return;
      const header = document.querySelector('.site-header');
      if (header && e.target instanceof Node && !header.contains(e.target)) {
        setOpen(false);
      }
    });
  }

  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>
