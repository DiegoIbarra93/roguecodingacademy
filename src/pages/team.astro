---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { teamPage } from '../data/copy';
import { team, getFounder } from '../data/team';
import { site } from '../data/site';
import {
  organizationSchema,
  personSchema,
  webPageSchema,
} from '../lib/schema';

const founder = getFounder();
const jsonLd = [
  organizationSchema(),
  webPageSchema({
    name: teamPage.title,
    description: teamPage.description,
    path: '/team',
    type: 'AboutPage',
  }),
  ...team.map(personSchema),
];
---

<BaseLayout title={teamPage.title} description={teamPage.description} jsonLd={jsonLd}>
  <Section eyebrow={site.name} title={teamPage.title} class="!pt-8 sm:!pt-14">
    <p class="mb-8 max-w-2xl text-base text-app-muted sm:mb-12 sm:text-lg">{teamPage.description}</p>

    <ul class="space-y-6 sm:space-y-10">
      {
        team.map((member) => (
          <li>
            <article class="glass-panel grid gap-5 overflow-hidden p-5 sm:grid-cols-[200px_1fr] sm:gap-8 sm:p-8 lg:p-10">
              <div class="relative mx-auto aspect-square w-full max-w-[140px] sm:max-w-[200px]">
                <div
                  class="flex h-full w-full items-center justify-center rounded-2xl border border-white/10 bg-gradient-to-br from-app-accent/20 via-app-surface to-app-river/40 font-display text-4xl font-bold text-app-accent shadow-tron-glow sm:text-5xl"
                  aria-hidden="true"
                >
                  {member.name
                    .split(' ')
                    .map((n) => n[0])
                    .join('')}
                </div>
              </div>
              <div>
                <p class="eyebrow">{member.role}</p>
                <h2 class="mt-2 font-display text-2xl font-semibold tracking-tight sm:text-3xl">
                  {member.name}
                </h2>
                {member.bio.map((para) => (
                  <p class="mt-3 text-sm text-app-muted sm:mt-4 sm:text-base">{para}</p>
                ))}
                <ul class="mt-5 flex flex-wrap gap-2 sm:mt-6">
                  {member.highlights.map((h) => (
                    <li class="rounded-lg border border-app-border/60 bg-app-accent-subtle px-3 py-1.5 text-xs text-app-mist">
                      {h}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          </li>
        ))
      }
    </ul>

    {
      founder && (
        <p class="mt-8 text-center text-sm text-app-muted sm:mt-12">
          Want to learn with {founder.name.split(' ')[0]}?{' '}
          <a href="/courses#request-seat" class="text-app-accent hover:text-app-mist">
            Request a seat
          </a>
        </p>
      )
    }
  </Section>
</BaseLayout>
