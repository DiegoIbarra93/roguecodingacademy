---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import HomeCinema from '../components/vue/HomeCinema.vue';
import { homeHero, eras, thesis, localClose } from '../data/copy';
import { site } from '../data/site';
import { organizationSchema, websiteSchema, webPageSchema } from '../lib/schema';

const jsonLd = [
  organizationSchema(),
  websiteSchema(),
  webPageSchema({
    name: site.name,
    description: site.description,
    path: '/',
  }),
];
---

<BaseLayout title={site.name} description={site.description} jsonLd={jsonLd}>
  <HomeCinema
    client:load
    hero={homeHero}
    eras={[...eras]}
    journeyEyebrow="Tech eras"
    journeyTitle="Always fast. Now faster."
  />

  <Section id="rapids">
    <div class="glass-panel relative overflow-hidden p-5 sm:p-8 md:p-12">
      <div
        class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-app-accent/15 blur-3xl"
        aria-hidden="true"
      ></div>
      <p class="eyebrow">{thesis.eyebrow}</p>
      <h2 class="mt-2 max-w-2xl font-display text-2xl font-semibold tracking-tight sm:mt-3 sm:text-3xl md:text-4xl">
        {thesis.headline}
      </h2>
      <p class="mt-4 max-w-2xl text-base text-app-muted sm:mt-5 sm:text-lg">{thesis.body}</p>
      <a href={thesis.cta.href} class="btn-primary mt-8 inline-flex w-full sm:mt-10 sm:w-auto">
        {thesis.cta.label}
      </a>
    </div>
  </Section>

  <Section>
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">{localClose.eyebrow}</p>
      <h2 class="mt-2 font-display text-xl font-semibold tracking-tight sm:mt-3 sm:text-2xl md:text-3xl">
        {localClose.headline}
      </h2>
      <p class="mt-3 text-base text-app-muted sm:mt-4">{localClose.body}</p>
    </div>
  </Section>
</BaseLayout>
